{
  "name": "vectorizer-gui",
  "version": "0.1.0",
  "description": "Desktop GUI for Vectorizer - High-performance vector database",
  "main": "dist-electron/main/main.js",
  "author": "HiveLLM Contributors",
  "license": "MIT",
  "homepage": "https://github.com/hivellm/vectorizer",
  "scripts": {
    "dev": "node dev-runner.js",
    "dev:simple": "node dev-runner-simple.js",
    "dev:check": "node check-dev.js",
    "dev:vite": "vite --host 0.0.0.0",
    "dev:electron": "tsc -p tsconfig.main.json && electron .",
    "build": "npx vite build && npx tsc -p tsconfig.main.json",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "electron:build": "pnpm build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "clean": "rimraf dist dist-electron dist-release",
    "type-check": "vue-tsc --noEmit && tsc -p tsconfig.main.json --noEmit"
  },
  "dependencies": {
    "@hivehub/vectorizer-sdk": "^3.0.0",
    "@monaco-editor/loader": "^1.7.0",
    "@vueuse/core": "^14.0.0",
    "conf": "^15.0.2",
    "electron-store": "^11.0.2",
    "js-yaml": "^4.1.1",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vis-data": "^8.0.3",
    "vis-network": "^10.0.2",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.6",
    "rimraf": "^5.0.5",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vue-tsc": "^3.1.5",
    "wait-on": "^7.2.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "glob": ">=10.5.0",
      "axios": ">=1.15.0",
      "follow-redirects": ">=1.16.0",
      "lodash": ">=4.18.0",
      "rollup": ">=4.59.0",
      "ajv": ">=8.18.0",
      "@xmldom/xmldom": ">=0.8.12",
      "@tootallnate/once": ">=3.0.1",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "vite@>=7.0.0 <7.3.2": "7.3.2"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "electron",
      "electron-winstaller",
      "esbuild",
      "vue-demi"
    ]
  },
  "build": {
    "appId": "io.hivellm.vectorizer-gui",
    "productName": "Vectorizer GUI",
    "copyright": "Copyright © 2025 HiveLLM Contributors",
    "directories": {
      "output": "dist-release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "!src/**/*",
      "!*.ts",
      "!tsconfig*.json",
      "!*.map"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "asar": false,
    "extraResources": [
      {
        "from": "../config.yml",
        "to": "config.yml"
      },
      {
        "from": "../target/release/vectorizer.exe",
        "to": "bin/vectorizer.exe",
        "filter": ["**/*"]
      },
      {
        "from": "../target/release/vectorizer-cli.exe",
        "to": "bin/vectorizer-cli.exe",
        "filter": ["**/*"]
      },
      {
        "from": "../config.example.yml",
        "to": "config.example.yml"
      }
    ],
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "category": "Development",
      "maintainer": "HiveLLM Contributors",
      "artifactName": "${name}_${version}_${arch}.${ext}"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "assets/icons/icon.icns",
      "background": "build/dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "deb": {
      "depends": [
        "gconf2",
        "gconf-service",
        "libnotify4",
        "libappindicator1",
        "libxtst6",
        "libnss3"
      ]
    }
  }
}