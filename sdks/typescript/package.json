{
  "name": "@hivehub/vectorizer-sdk",
  "version": "3.0.0",
  "description": "TypeScript SDK for Vectorizer - High-performance vector database. Ships the VectorizerRPC binary transport (default in v3.x) plus the legacy REST client.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "dev": "ts-node examples/basic-usage.ts",
    "publish:wsl": "export BROWSER=wslview && npm publish"
  },
  "keywords": [
    "vector-database",
    "semantic-search",
    "embeddings",
    "hnsw",
    "similarity-search",
    "typescript",
    "hivehub"
  ],
  "author": "HiveLLM Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hivellm/vectorizer.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/hivellm/vectorizer/issues"
  },
  "homepage": "https://github.com/hivellm/vectorizer#readme",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "js-yaml": "^4.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "picomatch@<2.3.2": "2.3.2"
    }
  }
}
